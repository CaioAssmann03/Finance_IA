# Copie este arquivo para .env.local e preencha com os valores do seu projeto Supabase
# (Project Settings > API no painel do Supabase)

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Chave da API da Anthropic (para categorização automática e assistente)
# Gerada em https://console.anthropic.com
ANTHROPIC_API_KEY=
